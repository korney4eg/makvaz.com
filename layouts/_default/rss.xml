{{- $posts := where .Site.RegularPages "Params.layout" "post" -}}
{{- $posts = $posts.ByDate.Reverse -}}
{{- $limit := .Site.Config.Services.RSS.Limit -}}
{{- if ge $limit 1 -}}
{{- $posts = $posts | first $limit -}}
{{- end -}}
{{- printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>{{ .Site.Title }}</title>
    <link>{{ .Permalink }}</link>
    <description>Recent posts from {{ .Site.Title }}</description>
    <generator>Hugo</generator>
    <language>{{ site.Language.LanguageCode }}</language>
    {{ with .Site.Params.author -}}
    <managingEditor>{{ . }}</managingEditor>
    {{- end }}
    {{ with .Site.Params.email -}}
    <webMaster>{{ . }}</webMaster>
    {{- end }}
    {{ with .Site.Copyright -}}
    <copyright>{{ . }}</copyright>
    {{- end }}
    {{ if not .Date.IsZero -}}
    <lastBuildDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" | safeHTML }}</lastBuildDate>
    {{- end }}
    {{- with .OutputFormats.Get "RSS" -}}
    {{ printf "<atom:link href=%q rel=\"self\" type=%q />" .Permalink .MediaType | safeHTML }}
    {{- end -}}
    {{ range $posts }}
    <item>
      <title>{{ .Title | markdownify | plainify | htmlUnescape }}</title>
      <link>{{ .Permalink }}</link>
      <pubDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" | safeHTML }}</pubDate>
      <guid>{{ .Permalink }}</guid>
      <description>{{ with .Summary }}{{ . | plainify | htmlUnescape }}{{ end }}</description>
    </item>
    {{ end }}
  </channel>
</rss>
